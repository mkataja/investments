{
  "name": "investments",
  "private": true,
  "engines": {
    "node": ">=25"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome check --write .",
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @investments/api dev\" \"pnpm --filter @investments/web dev\"",
    "db:generate": "pnpm --filter @investments/db generate",
    "db:migrate": "pnpm --filter @investments/db migrate",
    "db:studio": "pnpm --filter @investments/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test": "pnpm --filter @investments/api test && pnpm --filter @investments/web test",
    "ci": "concurrently -n lint,test,web,api -c cyan,magenta,blue,green \"pnpm lint\" \"pnpm test\" \"pnpm --filter @investments/web build\" \"pnpm --filter @investments/api build\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
