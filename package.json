{
  "name": "investments",
  "private": true,
  "engines": {
    "node": ">=25"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "biome check .",
    "ts-prune": "ts-prune --error -p api/tsconfig.json && ts-prune --error -p web/tsconfig.json",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome check --write .",
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @investments/api dev\" \"pnpm --filter @investments/web dev\"",
    "db:generate": "pnpm --filter @investments/db generate",
    "db:migrate": "pnpm --filter @investments/db migrate",
    "db:studio": "pnpm --filter @investments/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test": "pnpm --filter @investments/api test && pnpm --filter @investments/web test",
    "ci": "concurrently -n lint,ts-prune,test,web,api -c cyan,magenta,yellow,blue,green \"pnpm lint\" \"pnpm ts-prune\" \"pnpm test\" \"pnpm --filter @investments/web build\" \"pnpm --filter @investments/api build\"",
    "loc": "sloc api db lib web -e \"(node_modules|dist|\\\\.turbo|\\\\.data|coverage)\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.2",
    "sloc": "^0.3.2",
    "ts-prune": "^0.10.3",
    "typescript": "^5.7.3"
  }
}
