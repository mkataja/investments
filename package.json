{
  "name": "investments",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @investments/api dev\" \"pnpm --filter @investments/web dev\"",
    "db:generate": "pnpm --filter @investments/db generate",
    "db:migrate": "pnpm --filter @investments/db migrate",
    "db:studio": "pnpm --filter @investments/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
